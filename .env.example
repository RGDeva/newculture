# ── NewCulture runtime config ─────────────────────────────────────────────
# Copy this to .env.local for local dev, and set the same values in Vercel
# → Project → Settings → Environment Variables for production.

# Contact + booking
VITE_CONTACT_EMAIL=hello@newculture.co
VITE_CAL_URL=https://cal.com/newculture/strategy

# Supabase (for all submissions + admin)
# Project settings → API → Project URL and anon/public key
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Admin panel password for /admin/applications
# Use a strong value in production.
VITE_ADMIN_PASSWORD=change-me

# Stripe (for productized offers)
# Get from Stripe Dashboard → Developers → API keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# RoEx API (for mix/master analysis)
# Provided key: AIzaSyB4APe-Ll9TCjvKyouegkbaQoXQ41R9ITg
# Portal: https://tonn-portal.roexaudio.com/
VITE_ROEX_API_KEY=AIzaSyB4APe-Ll9TCjvKyouegkbaQoXQ41R9ITg
VITE_ROEX_API_URL=https://tonn-api.roexaudio.com/v1

# Recoupable API (for artist research & strategy)
# Provided key: recoup_sk_9wMCq6Y0JLhqrq5KKQ7F0v1qewI3mySUi0KIfQG5Pk0
# Docs: https://developers.recoupable.com/
VITE_RECOUPABLE_API_KEY=recoup_sk_9wMCq6Y0JLhqrq5KKQ7F0v1qewI3mySUi0KIfQG5Pk0
VITE_RECOUPABLE_API_URL=https://recoup-api.vercel.app/api

# ONCE API (for release operations)
# ONCE uses MCP protocol with OAuth browser flow (not simple API key)
# MCP Server: https://beta.once.app/api/mcp
# To obtain access token:
#   1. Create account at https://once.app
#   2. Go to https://docs.once.app/mcp/agents for setup guide
#   3. Complete OAuth flow - returns Bearer token
#   4. Store token here as VITE_ONCE_API_KEY
VITE_ONCE_API_KEY=your_once_bearer_token
VITE_ONCE_API_URL=https://beta.once.app/api/mcp
